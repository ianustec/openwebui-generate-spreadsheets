        "excel_table": true,
        "freeze": "A2",
        "auto_filter": true,
        "totals_row": true,
        "conditional_formatting": [
          { "type": "data_bar", "column": "q1", "color": "1E3A5F" },
          { "type": "data_bar", "column": "q2", "color": "1E3A5F" },
          { "type": "data_bar", "column": "q3", "color": "1E3A5F" },
          { "type": "data_bar", "column": "q4", "color": "1E3A5F" },
          { "type": "data_bar", "column": "fy", "color": "2E7D32" }
        ]
      }
    },
    {
      "name": "By segment",
      "kind": "matrix",
      "title": "Revenue by segment × quarter",
      "columns": [
        { "key": "segment", "header": "Segment", "format": "text", "width": 22 },
        { "key": "q1", "header": "Q1", "format": "currency", "width": 12 },
        { "key": "q2", "header": "Q2", "format": "currency", "width": 12 },
        { "key": "q3", "header": "Q3", "format": "currency", "width": 12 },
