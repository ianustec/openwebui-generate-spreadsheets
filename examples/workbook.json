      "excel_table": true,
      "conditional_formatting": [
        { "type": "color_scale", "column": "q1" },
        { "type": "color_scale", "column": "q2" },
        { "type": "color_scale", "column": "q3" },
        { "type": "color_scale", "column": "q4" },
        { "type": "color_scale", "column": "fy" }
      ]
    },
    {
      "name": "Pipeline",
      "kind": "table",
      "title": "Sales pipeline — weighted",
      "table": {
        "name": "Pipeline",
        "columns": [
          { "key": "deal", "header": "Opportunity", "width": 26 },
          { "key": "owner", "header": "Owner", "width": 14 },
          { "key": "stage", "header": "Stage", "width": 14 },
          { "key": "amount", "header": "Amount", "format": "currency", "width": 12 },
          { "key": "prob", "header": "Win %", "format": "percent", "width": 10 },
          {
            "key": "weighted",
            "header": "Weighted",
            "format": "currency",
            "width": 12,
            "formula": "=[{amount}]*[{prob}]"
          },
          { "key": "close", "header": "Close", "format": "date", "width": 12 }
        ],
        "rows": [
          { "deal": "Acme Corp — platform rollout", "owner": "M. Chen", "stage": "Negotiate", "amount": 280000, "prob": 0.7, "close": "2026-04-15" },
          { "deal": "Globex AI copilot suite", "owner": "J. Patel", "stage": "Proposal", "amount": 145000, "prob": 0.45, "close": "2026-05-30" },
          { "deal": "Initech multi-year MSA", "owner": "M. Chen", "stage": "Qualify", "amount": 420000, "prob": 0.25, "close": "2026-08-01" },
          { "deal": "Umbrella regional expansion", "owner": "S. Okonkwo", "stage": "Negotiate", "amount": 96000, "prob": 0.65, "close": "2026-03-20" },
          { "deal": "Stark Industries SOC2 pack", "owner": "J. Patel", "stage": "Closed Won", "amount": 72000, "prob": 1.0, "close": "2026-02-10" },
          { "deal": "Wayne Health LLM pilot", "owner": "S. Okonkwo", "stage": "Proposal", "amount": 118000, "prob": 0.4, "close": "2026-06-15" },
          { "deal": "Oscorp data platform", "owner": "M. Chen", "stage": "Qualify", "amount": 195000, "prob": 0.2, "close": "2026-09-01" }
        ],
        "excel_table": true,
        "freeze": "A2",
        "totals_row": true,
        "conditional_formatting": [
          { "type": "data_bar", "column": "weighted", "color": "2E7D32" },
          {
            "type": "cell_value",
            "column": "prob",
            "operator": "greaterThanOrEqual",
            "value": 0.6,
            "fill": "C8E6C9"
          }
        ],
        "validation": [
          {
            "column": "stage",
            "type": "list",
            "options": ["Qualify", "Proposal", "Negotiate", "Closed Won", "Closed Lost"]
          }
        ]
      }
